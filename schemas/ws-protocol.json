{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WebSocket Protocol",
  "description": "Messages exchanged between Frontend and Gateway",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "enum": ["USER_INPUT", "AGENT_EVENT", "APPROVAL_REQ", "APPROVAL_RES", "ERROR"]
    },
    "project_id": { "type": "string", "format": "uuid" },
    "agent_name": { "type": "string" },
    "event_type": { "type": "string", "enum": ["chunk", "tool_call", "tool_result", "result"] },
    "content": { "type": "string" },
    "approved": { "type": "boolean" },
    "feedback": { "type": "string" },
    "payload": { "type": "object" },
    "timestamp": { "type": "string", "format": "date-time" }
  },
  "required": ["type", "project_id"]
}
